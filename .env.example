OPENAI_QUERY_EMBED_CACHE_TTL_SECONDS=86400
OPENAI_QUERY_EMBED_CACHE_MAX_CHARS=280
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_RAG_KNOWLEDGE_MAX_CHUNKS=4
OPENAI_RAG_KNOWLEDGE_MIN_SCORE=0.63
OPENAI_RAG_KNOWLEDGE_MAX_CONTEXT_CHARS=2600
OPENAI_RAG_PRODUCTS_MIN_SEMANTIC_SCORE=0.48

WIDGET_SESSION_TOKEN_TTL_SECONDS=86400
WIDGET_ALLOW_MISSING_ORIGIN=false
