WIDGET_RATE_LIMIT_CHECKOUT_PER_MINUTE=24
WIDGET_RATE_LIMIT_LEAD_PER_MINUTE=30
WIDGET_RATE_LIMIT_EVENT_PER_MINUTE=90
WIDGET_RATE_LIMIT_IP_PER_MINUTE=240
