OPENAI_DEFAULT_MAX_OUTPUT_TOKENS=350
OPENAI_MAX_OUTPUT_TOKENS_CEILING=1200
OPENAI_RESPONSE_MAX_CHARS=520
OPENAI_FORCE_LIVE_RESPONSES=true
